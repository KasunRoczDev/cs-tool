# Backend configuration
PORT=4000
NODE_ENV=development

# PostgreSQL / TimescaleDB
DATABASE_URL=postgres://monitor:monitor@localhost:5432/monitoring

# JWT for dashboard users
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=12h

# CORS origin for the dashboard
DASHBOARD_ORIGIN=http://localhost:5173

# Alert engine thresholds (percent / counts)
ALERT_CPU_THRESHOLD=90
ALERT_MEM_THRESHOLD=90
ALERT_DISK_THRESHOLD=90
ALERT_OFFLINE_SECONDS=120
ALERT_SSH_BRUTEFORCE_COUNT=5
ALERT_SSH_BRUTEFORCE_WINDOW_SEC=60

# Optional notification channels
SLACK_WEBHOOK_URL=
